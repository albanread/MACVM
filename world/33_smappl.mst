"33_smappl.mst — the image-side half of the `<smappl visual=...>` tag
 (gui/smappl.md §3 shapes 1/2/6: icon button, labeled button, glue/side-effect).

 A visual= expression evaluates to a Visual; `VmHandle::render_fragment`
 sends it #htmlFragment and splices the answer into the page (GUI decision
 D-G5 / docs/APPS.md §6: the Visual renders ITSELF to HTML — Rust only
 transports the string). Live widget actions are closures kept in
 SmapplRegistry, keyed by an opaque id the rendered HTML carries in
 `data-widget-action`; a click posts {kind:smapplAction,id}, which the GUI
 worker turns into `SmapplRegistry fire: id` (gui/PLAN.md G1: route by opaque
 id through a worker-owned handler table).

 Scope: the button/glue/side-effect shapes only. The outliner/CodeView
 shapes (gui/smappl.md §3.3-3.5) need the Phase-W mirror stack (docs/APPS.md
 §2) and render as the G0 placeholder box until then. HTML escaping of labels
 is deliberately omitted here (the shipped corpus labels are ASCII-safe) — a
 follow-up when arbitrary label text becomes reachable."

"--- SmapplRegistry: opaque-id -> live widget (the visualRegistry analog) ---"
Object subclass: SmapplRegistry [
    <classVars: Widgets Counter>

    SmapplRegistry class >> reset [
        Widgets := Dictionary new.
        Counter := 0.
    ]
    SmapplRegistry class >> register: aVisual [
        "Stash a widget under a fresh opaque id and answer the id."
        | id |
        Widgets isNil ifTrue: [ self reset ].
        Counter := Counter + 1.
        id := 'w', Counter printString.
        Widgets at: id put: aVisual.
        ^id
    ]
    SmapplRegistry class >> fire: id [
        "A rendered widget was clicked: run its action. Unknown id = no-op
         (a stale fragment from before the last reset)."
        Widgets isNil ifTrue: [ ^nil ].
        ^(Widgets at: id ifAbsent: [ ^nil ]) activate
    ]
]

"--- Visual: base of the embeddable widget hierarchy ---"
Object subclass: Visual [
    Visual class >> coerce: anObject [
        "The generic dynamic cast ElementSMAPPL uses (gui/smappl.md §2). MACVM
         trusts the value; a non-Visual falls through to #htmlFragment, whose
         DNU render_fragment turns into the placeholder box."
        ^anObject
    ]
    htmlFragment [
        "Default: an inert placeholder. Real widgets override."
        ^'<span class="smappl-box">smappl</span>'
    ]
    activate [
        "Click hook; a plain Visual does nothing."
        ^self
    ]
    promptOk: aString title: aTitle type: aSymbol action: aBlock [
        "The native modal dialog a widget action pops (gui/smappl.md §3 shape 2
         — differences2.html's 'Press Me!' button: `b promptOk: msg title: t
         type: #info action: []`). Answers the dialog as an HTML overlay
         fragment; the GUI worker recognises a String result from `fire:` and
         injects it (VmResponse::SmapplOverlay). Faithful to A19 — the image
         describes the dialog, Rust only displays it.

         `aSymbol` (#info/#warning/#error) picks the accent. `aBlock` is the
         after-OK continuation; the shipped corpus always passes [], so OK just
         closes the overlay client-side and the block is not run — wire it when
         a non-empty continuation becomes reachable. Label text isn't escaped
         (corpus strings are ASCII-safe), matching Button>>htmlFragment."
        | kind |
        kind := aSymbol == #warning
            ifTrue: [ 'warning' ]
            ifFalse: [ aSymbol == #error ifTrue: [ 'error' ] ifFalse: [ 'info' ] ].
        ^'<div class="st-modal" data-modal><div class="st-modal-box st-modal-', kind, '">',
         '<div class="st-modal-title">', aTitle, '</div>',
         '<div class="st-modal-msg">', aString, '</div>',
         '<div class="st-modal-actions"><button class="smappl-button bevel-raised st-modal-ok">OK</button></div>',
         '</div></div>'
    ]
    "Corpus decoration chain (gui/smappl.md §3.4-3.5): these wrap a Visual in
     a border/hrule frame on-screen. For the HTML bridge they are identity —
     the border lives in CSS (.st-outliner) — so the whole
     `... topVisualWithHRule: false withBorder: (Border standard3DRaised: true)`
     tail just answers the receiver, which still responds to #htmlFragment."
    topVisualWithHRule: aBool [ ^self ]
    withBorder: aBorder [ ^self ]
    with3DBorder [ ^self ]
]

"--- Border: a decoration descriptor (identity for the HTML bridge) ---"
Object subclass: Border [
    Border class >> standard3DRaised: aBool [ ^self ]
]

"--- Glue: an invisible rigid spacer (gui/smappl.md §3 shape 6) ---"
Visual subclass: Glue [
    | size |
    Glue class >> xRigid: n [
        ^self basicNew setSize: n
    ]
    setSize: n [
        size := n.
        ^self
    ]
    htmlFragment [
        ^'<span class="glue" style="display:inline-block;width:', size printString, 'px"></span>'
    ]
]

"--- Button: labeled (shape 2) and icon (shape 1) push buttons ---"
Visual subclass: Button [
    | label iconName action |
    Button class >> labeled: aString action: aBlock [
        ^self basicNew setLabel: aString action: aBlock
    ]
    Button class >> withImage: anImage action: aBlock [
        "anImage answers a logical icon name (see Image>>logicalName). The GUI
         resolves it to a theme-appropriate asset at insertion time
         (gui/smappl.md §5), so the image side stays theme-agnostic."
        ^self basicNew setIcon: anImage logicalName action: aBlock
    ]
    setLabel: aString action: aBlock [
        label := aString.
        action := aBlock.
        ^self
    ]
    setIcon: aName action: aBlock [
        iconName := aName.
        action := aBlock.
        ^self
    ]
    activate [
        action isNil ifTrue: [ ^self ].
        ^action value: self
    ]
    htmlFragment [
        | id inner |
        id := SmapplRegistry register: self.
        inner := iconName isNil
            ifTrue: [ label ]
            ifFalse: [ '<img class="smappl-icon" width="20" height="20" data-icon="', iconName, '">' ].
        ^'<button class="smappl-button bevel-raised" data-widget-action="', id, '">', inner, '</button>'
    ]
]

"--- Image/FilePath: just enough to carry an icon path (gui/smappl.md §5) ---"
Object subclass: FilePath [
    | path |
    FilePath class >> for: aString [
        ^self basicNew setPath: aString
    ]
    setPath: s [
        path := s.
        ^self
    ]
    path [
        ^path
    ]
]

Object subclass: Image [
    | source |
    Image class >> fromFile: aFilePath [
        ^self basicNew setSource: aFilePath
    ]
    setSource: fp [
        source := fp.
        ^self
    ]
    logicalName [
        "The raw path, e.g. 'resources/edit.bmp'; the GUI strips the
         resources/ prefix and .bmp suffix and maps the name through the
         active theme (gui/smappl.md §5)."
        ^source path
    ]
]

"--- Environment tool stubs (gui/smappl.md §3.6 doit/action vocabulary) ---
 The tour pages' toolbar buttons act on Strongtalk's Launcher/Workspace/
 CodeEditor/HTMLView. MACVM has no Smalltalk UI (the environment is HTML/JS), so
 these are thin stubs that (a) COMPILE — which is what lets the surrounding
 `Button withImage: ... action: [ :b | Launcher launchers anElement browseStartPage ]`
 expressions build a LIVE button instead of failing to the G0 placeholder — and
 (b) answer a `'macvm-nav:TARGET'` marker string. When such a button is clicked,
 the worker (vm_host SmapplAction) recognises the prefix and routes TARGET to the
 matching native toolbar action (main.rs), so the click opens MACVM's equivalent
 view. TARGET values are the toolbar action names: home / hierarchy /
 userHierarchy / find / implementors / senders / workspace / documentation."

"The clicked launcher element: the corpus sends it browse/open/find messages;
 each answers the navigation marker for MACVM's matching view."
Object subclass: LauncherElement [
    browseStartPage [ ^'macvm-nav:home' ]
    openClassHierarchyOutliner [ ^'macvm-nav:hierarchy' ]
    openUserClassHierarchyOutliner [ ^'macvm-nav:userHierarchy' ]
    findDefinition [ ^'macvm-nav:find' ]
    findImplementors [ ^'macvm-nav:implementors' ]
    findSenders [ ^'macvm-nav:senders' ]
    "Strongtalk runs a find on the session process; here just evaluate the block
     and answer its marker (`l inSessionProcessDo: [ l findImplementors ]`)."
    inSessionProcessDo: aBlock [ ^aBlock value ]
]

"`Launcher launchers anElement` → the LauncherElement above."
Object subclass: Launcher [
    Launcher class >> launchers [ ^self ]
    Launcher class >> anElement [ ^LauncherElement basicNew ]
]

"`Workspace new launch` / `CodeEditor new launch` / `HTMLView forDoc launch`."
Object subclass: Workspace [
    Workspace class >> new [ ^self basicNew ]
    launch [ ^'macvm-nav:workspace' ]
]

Object subclass: CodeEditor [
    CodeEditor class >> new [ ^self basicNew ]
    launch [ ^'macvm-nav:workspace' ]
]

Object subclass: HTMLView [
    HTMLView class >> forDoc [ ^self basicNew ]
    launch [ ^'macvm-nav:documentation' ]
]

SmapplRegistry reset.
