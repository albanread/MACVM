"61_posix_io.mst — POSIX I/O through the S20 FFI (docs/asyncio_design.md
 slice A; roadmap item 3, async I/O). Pure Smalltalk + the existing FFI —
 zero new Rust.

 The design constraint that shapes everything here: the FFI cannot call
 VARIADIC functions (Apple arm64 puts variadic args on the stack, the
 trampoline loads registers — docs/FFI.md §6.2), so fcntl(F_SETFL,
 O_NONBLOCK) is out of reach. It is also unnecessary: kevent(2) reports
 readiness WITH AMOUNTS — `data` is the readable byte count (or writable
 space, or pending-connection count) — so a read/write/accept bounded by
 what kevent reported never blocks, even on ordinary blocking fds.

 Memory passed to the kernel comes from mmap (the S20 capstone call):
 NativeBuffer below wraps one anonymous page whose address is a plain
 SmallInteger for #g args AND an indirect Alien for byte access. Unlike a
 heap object, its address is GC-stable — safe to hand to a syscall that
 writes into it.

 Layers:
   Posix        — raw class-side FFI bindings (fixed-arity libc only)
   NativeBuffer — one mmap'd page: address + Alien + 16/32-bit accessors
                  (Alien natively does 1- and 8-byte; wider fields are
                  composed little-endian) + kevent-struct pack/unpack
   Kqueue       — watch/unwatch fds, poll events; the readiness engine the
                  slice-B IoWorker event loop is built on"

Object subclass: Posix [
    <classVars: Scratch>
    "── raw bindings — every one fixed-arity (no variadic tail) ──"
    Posix class >> kqueue [
        <primitive: FFI function: #kqueue ret: #g args: #()>
    ]
    "kevent(kq, changelist, nchanges, eventlist, nevents, timeout) — 6 #g
     args, the same proven arity as the mmap capstone."
    Posix class >> keventKq: kq changes: cl nChanges: nc events: ev nEvents: ne timeout: ts [
        <primitive: FFI function: #kevent ret: #g args: #(g g g g g g)>
    ]
    Posix class >> pipeInto: fdsAddr [
        <primitive: FFI function: #pipe ret: #g args: #(g)>
    ]
    Posix class >> read: fd into: bufAddr count: n [
        <primitive: FFI function: #read ret: #g args: #(g g g)>
    ]
    Posix class >> write: fd from: bufAddr count: n [
        <primitive: FFI function: #write ret: #g args: #(g g g)>
    ]
    Posix class >> close: fd [
        <primitive: FFI function: #close ret: #g args: #(g)>
    ]
    Posix class >> socketpairDomain: d type: t protocol: p into: svAddr [
        <primitive: FFI function: #socketpair ret: #g args: #(g g g g)>
    ]
    "── TCP sockets — all fixed-arity, so all FFI-reachable ──
     AF_INET = 2, SOCK_STREAM = 1. accept/getsockname take a value-result
     socklen POINTER (or 0/0 to ignore the peer address)."
    Posix class >> socketDomain: d type: t protocol: p [
        <primitive: FFI function: #socket ret: #g args: #(g g g)>
    ]
    Posix class >> bind: fd addr: sa len: l [
        <primitive: FFI function: #bind ret: #g args: #(g g g)>
    ]
    Posix class >> listen: fd backlog: b [
        <primitive: FFI function: #listen ret: #g args: #(g g)>
    ]
    Posix class >> accept: fd addr: sa lenPtr: lp [
        <primitive: FFI function: #accept ret: #g args: #(g g g)>
    ]
    Posix class >> connect: fd addr: sa len: l [
        <primitive: FFI function: #connect ret: #g args: #(g g g)>
    ]
    Posix class >> getsockname: fd addr: sa lenPtr: lp [
        <primitive: FFI function: #getsockname ret: #g args: #(g g g)>
    ]
    Posix class >> mmapAddr: a length: l prot: pr flags: f fd: fd offset: o [
        <primitive: FFI function: #mmap ret: #g args: #(g g g g g g)>
    ]
    "errno lives behind __error() on macOS — a 0-arg function answering
     int*. Wrap the pointer as a 4-byte indirect Alien and compose the int."
    Posix class >> errnoAddress [
        <primitive: FFI function: #__error ret: #g args: #()>
    ]
    Posix class >> errno [
        | a |
        a := Alien forAddress: self errnoAddress size: 4.
        ^(a byteAt: 1) + ((a byteAt: 2) * 256)
            + ((a byteAt: 3) * 65536) + ((a byteAt: 4) * 16777216)
    ]

    "── conveniences ──"
    "One anonymous page: PROT_READ|PROT_WRITE = 3, MAP_PRIVATE|MAP_ANON =
     4098 (0x1002) — the capstone test's own proven macOS/arm64 values."
    Posix class >> mmapPage [
        ^self mmapAddr: 0 length: 4096 prot: 3 flags: 4098 fd: -1 offset: 0
    ]
]

Object subclass: NativeBuffer [
    | addr alien |
    NativeBuffer class >> page [ ^self basicNew initPage ]
    initPage [
        addr := Posix mmapPage.
        alien := Alien forAddress: addr size: 4096.
        ^self
    ]
    address [ ^addr ]
    "`off` is 0-based throughout this class (matching C struct offsets);
     Alien accessors are 1-based, hence the +1s."
    byteAt: off [ ^alien byteAt: off + 1 ]
    byteAt: off put: v [ ^alien byteAt: off + 1 put: v ]
    i64At: off [ ^alien signedLongAt: off + 1 ]
    i64At: off put: v [ ^alien signedLongAt: off + 1 put: v ]
    u16At: off put: v [
        alien byteAt: off + 1 put: v \\ 256.
        alien byteAt: off + 2 put: v // 256 \\ 256
    ]
    u16At: off [ ^(alien byteAt: off + 1) + ((alien byteAt: off + 2) * 256) ]
    u32At: off [
        ^(alien byteAt: off + 1) + ((alien byteAt: off + 2) * 256)
            + ((alien byteAt: off + 3) * 65536) + ((alien byteAt: off + 4) * 16777216)
    ]
    u32At: off put: v [
        alien byteAt: off + 1 put: v \\ 256.
        alien byteAt: off + 2 put: v // 256 \\ 256.
        alien byteAt: off + 3 put: v // 65536 \\ 256.
        alien byteAt: off + 4 put: v // 16777216 \\ 256
    ]
    zero: nBytes at: off [
        1 to: nBytes do: [ :i | alien byteAt: off + i put: 0 ]
    ]

    "── struct kevent (macOS/arm64, 32 bytes) ──────────────────────────────
       0  ident   uintptr_t   8    16 data   intptr_t  8
       8  filter  int16_t     2    24 udata  void*     8
      10  flags   uint16_t    2
      12  fflags  uint32_t    4"
    keventAt: off ident: fd filter: filt flags: fl [
        ^self keventAt: off ident: fd filter: filt flags: fl fflags: 0
    ]
    keventAt: off ident: fd filter: filt flags: fl fflags: ff [
        | f16 |
        self zero: 32 at: off.
        self i64At: off put: fd.
        "filter is a NEGATIVE i16 (EVFILT_READ = -1, EVFILT_WRITE = -2,
         EVFILT_USER = -10): two's-complement it into an unsigned 16-bit
         field. fflags carries NOTE_TRIGGER for user events."
        f16 := filt < 0 ifTrue: [ filt + 65536 ] ifFalse: [ filt ].
        self u16At: off + 8 put: f16.
        self u16At: off + 10 put: fl.
        self u32At: off + 12 put: ff
    ]
    keventIdentAt: off [ ^self i64At: off ]
    keventFilterAt: off [
        | v | v := self u16At: off + 8.
        ^v >= 32768 ifTrue: [ v - 65536 ] ifFalse: [ v ]
    ]
    keventFlagsAt: off [ ^self u16At: off + 10 ]
    keventDataAt: off [ ^self i64At: off + 16 ]

    "── struct timespec (16 bytes: tv_sec i64, tv_nsec i64) ──"
    timespecAt: off ms: ms [
        self i64At: off put: ms // 1000.
        self i64At: off + 8 put: ms \\ 1000 * 1000000
    ]

    "── struct sockaddr_in (Darwin, 16 bytes) ──────────────────────────
       0  sin_len    u8 (= 16)     4  sin_addr  u32 NETWORK order
       1  sin_family u8 (AF_INET)  8  sin_zero  [8]
       2  sin_port   u16 NETWORK order
     Port and address are BIG-endian (network order) — packed byte-wise,
     deliberately not via the little-endian u16/u32 accessors. Loopback =
     127.0.0.1; port 0 asks the kernel for an ephemeral port."
    sockaddrInLoopbackAt: off port: port [
        self zero: 16 at: off.
        self byteAt: off put: 16.
        self byteAt: off + 1 put: 2.
        self byteAt: off + 2 put: port // 256.
        self byteAt: off + 3 put: port \\ 256.
        self byteAt: off + 4 put: 127.
        self byteAt: off + 7 put: 1
    ]
    sockaddrInPortAt: off [
        ^(self byteAt: off + 2) * 256 + (self byteAt: off + 3)
    ]
]

"── Posix reopened: TCP conveniences (they need NativeBuffer, defined above —
 the reopen-after-defining pattern, as 28_point.mst does for Number) ─────────
 Loopback only: binding to 127.0.0.1 (never 0.0.0.0) keeps everything
 on-machine AND avoids the macOS firewall prompt; port 0 lets the kernel
 assign an ephemeral port, which `boundPortOf:` reads back — no hardcoded
 ports, no collisions between parallel test runs. One lazy scratch page per
 VM for the sockaddr/socklen arguments (each VM is strictly serial, so
 sequential reuse is safe)."
Object subclass: Posix [
    Posix class >> scratch [
        Scratch isNil ifTrue: [ Scratch := NativeBuffer page ].
        ^Scratch
    ]
    Posix class >> tcpSocket [ ^self socketDomain: 2 type: 1 protocol: 0 ]
    Posix class >> tcpListenLoopback: backlog [
        | fd rc |
        fd := self tcpSocket.
        fd < 0 ifTrue: [ ^fd ].
        self scratch sockaddrInLoopbackAt: 0 port: 0.
        rc := self bind: fd addr: self scratch address len: 16.
        rc < 0 ifTrue: [ ^rc ].
        rc := self listen: fd backlog: backlog.
        rc < 0 ifTrue: [ ^rc ].
        ^fd
    ]
    Posix class >> boundPortOf: fd [
        self scratch u32At: 64 put: 16.        "value-result socklen"
        self getsockname: fd addr: self scratch address lenPtr: self scratch address + 64.
        ^self scratch sockaddrInPortAt: 0
    ]
    "Blocking connect is safe HERE and only here: against a loopback
     listener with backlog space, the kernel completes the handshake
     immediately — no remote peer, no accept() needed first."
    Posix class >> tcpConnectLoopback: port [
        | fd rc |
        fd := self tcpSocket.
        fd < 0 ifTrue: [ ^fd ].
        self scratch sockaddrInLoopbackAt: 0 port: port.
        rc := self connect: fd addr: self scratch address len: 16.
        rc < 0 ifTrue: [ ^rc ].
        ^fd
    ]
    "Accept ignoring the peer address (0/0 is the documented 'don't care').
     Only ever called when kevent reported a pending connection, so it
     cannot block even on a blocking listener."
    Posix class >> acceptOn: fd [ ^self accept: fd addr: 0 lenPtr: 0 ]
]

"── Kqueue: the readiness engine ────────────────────────────────────────────
 One kqueue fd + one page, carved:
   0..31    the one-slot changelist (register/deregister)
   64..319  the eventlist (up to 8 events per poll)
   384..399 the poll timespec
   512..    scratch (callers may use `buffer` for read/write payloads)
 EVFILT_READ = -1, EVFILT_WRITE = -2, EVFILT_USER = -10; EV_ADD|EV_ENABLE
 = 5, EV_DELETE = 2, EV_ADD|EV_ENABLE|EV_CLEAR = 37; NOTE_TRIGGER =
 16777216 (0x01000000); EV_EOF = 32768 (the u16 top bit, so `flags >=
 32768` tests it without needing bitAnd:).

 EVFILT_USER is the kqueue-native USER SIGNAL: register it once, and any
 thread holding the kq fd can fire it with a NOTE_TRIGGER kevent call —
 the sleeping poll returns NOW, and a trigger fired while nobody sleeps
 LATCHES until the next poll (EV_CLEAR resets it on delivery). That
 latching is the no-lost-wakeup property a raw POSIX signal cannot give
 kevent on Darwin (there is no pselect-style atomic-mask kevent), and it
 is what the IoWorker's wake rides on (world/62). Since worker VMs share
 one fd table, `Kqueue onFd:` lets another VM poke the SAME kernel kqueue
 through its own handle."
Object subclass: Kqueue [
    | kq buf |
    Kqueue class >> new [ ^self basicNew init ]
    "Wrap an EXISTING kqueue fd (made elsewhere — e.g. by the primary VM,
     which bakes it into the IoWorker's boot doit). Own page, shared
     kernel object; concurrent kevent calls on one kq from two threads are
     safe (the libdispatch wake pattern)."
    Kqueue class >> onFd: anFd [ ^self basicNew initOnFd: anFd ]
    init [ ^self initOnFd: Posix kqueue ]
    initOnFd: anFd [
        kq := anFd.
        buf := NativeBuffer page.
        ^self
    ]
    fd [ ^kq ]
    buffer [ ^buf ]

    change: fd filter: filt flags: fl [
        ^self change: fd filter: filt flags: fl fflags: 0
    ]
    change: fd filter: filt flags: fl fflags: ff [
        buf keventAt: 0 ident: fd filter: filt flags: fl fflags: ff.
        ^Posix keventKq: kq changes: buf address nChanges: 1
              events: 0 nEvents: 0 timeout: 0
    ]
    watchRead: fd [ ^self change: fd filter: -1 flags: 5 ]
    watchWrite: fd [ ^self change: fd filter: -2 flags: 5 ]
    unwatchRead: fd [ ^self change: fd filter: -1 flags: 2 ]
    unwatchWrite: fd [ ^self change: fd filter: -2 flags: 2 ]

    "── the user event (ident 0): register once, poke from anywhere ──"
    registerUserEvent [ ^self change: 0 filter: -10 flags: 37 fflags: 0 ]
    triggerUserEvent [ ^self change: 0 filter: -10 flags: 0 fflags: 16777216 ]

    "Poll with a millisecond timeout (0 = return immediately). Answers an
     Array of per-event Arrays {ident. filter. data. flags} — `data` is the
     byte count/space/backlog that makes bounded blocking-fd I/O safe."
    pollMs: ms [
        buf timespecAt: 384 ms: ms.
        ^self pollTimeoutPtr: buf address + 384
    ]
    "Block in kevent with NO timeout (NULL timespec): zero CPU until an
     event — or the user event — arrives. The IoWorker's idle state."
    pollForever [ ^self pollTimeoutPtr: 0 ]
    pollTimeoutPtr: tsPtr [
        | n events |
        n := Posix keventKq: kq changes: 0 nChanges: 0
                  events: buf address + 64 nEvents: 8
                  timeout: tsPtr.
        n < 0 ifTrue: [ ^Array new: 0 ].
        events := Array new: n.
        1 to: n do: [ :i |
            | off e |
            off := 64 + (i - 1 * 32).
            e := Array new: 4.
            e at: 1 put: (buf keventIdentAt: off).
            e at: 2 put: (buf keventFilterAt: off).
            e at: 3 put: (buf keventDataAt: off).
            e at: 4 put: (buf keventFlagsAt: off).
            events at: i put: e ].
        ^events
    ]

    close [ ^Posix close: kq ]
]

"── Posix reopened: file open/seek/unlink bindings ───────────────────────────
 All fixed-arity, so all FFI-reachable. The one trap is open(2): its optional
 third `mode` argument is VARIADIC, and Apple arm64 puts variadic args on the
 stack while the trampoline loads registers (docs/FFI.md §6.2, and the header
 of this file) — so a 3-arg #(g g g) `open` binding would mis-marshal `mode`.
 The fix is to split the two real uses:
   • opening an EXISTING file needs no mode -> open(path, flags), a clean
     2-arg #(g g) binding (never pass O_CREAT through this one — with no mode
     the kernel reads a garbage permission word off the stack);
   • CREATING a file goes through creat(path, mode), which is a fixed 2-arg
     libc call equal to open(path, O_WRONLY|O_CREAT|O_TRUNC, mode).
 Together they cover read-existing and write-fresh — everything slurp/spit and
 the common File surface need — with no variadic call anywhere. lseek's off_t
 is a 64-bit register (#g); unlink is a lone path pointer."
Object subclass: Posix [
    Posix class >> openPath: pathAddr flags: fl [
        <primitive: FFI function: #open ret: #g args: #(g g)>
    ]
    Posix class >> creatPath: pathAddr mode: m [
        <primitive: FFI function: #creat ret: #g args: #(g g)>
    ]
    Posix class >> lseekFd: fd offset: off whence: w [
        <primitive: FFI function: #lseek ret: #g args: #(g g g)>
    ]
    Posix class >> unlinkPath: pathAddr [
        <primitive: FFI function: #unlink ret: #g args: #(g)>
    ]
]

"── PosixFile: an fd wrapped in a Smalltalk object ───────────────────────────
 The low-level, byte-exact half of the file surface (the encoding-aware half
 is CocoaFile, world/49a). fd-level read/write/seek plus whole-file slurp/spit
 built on NativeBuffer — a String and a ByteArray are both IndexableBytes, so
 the bytes a file holds ARE a String's UTF-8 bytes (no re-encoding); reads
 accumulate through a WriteStream (bulk replaceFrom: memcpy) and writes drain
 a String's bytes back out a page at a time, looping on the count the kernel
 actually moved (partial writes handled).

 Memory handed to read(2)/write(2)/open(2) must be GC-stable, so it comes from
 an mmap'd NativeBuffer, never a heap String. One lazy class-side scratch page
 is reused for BOTH path-staging and chunk I/O — safe because a VM is strictly
 serial and the path is consumed by open() before any read/write touches the
 page. A file whose open fails answers nil (errno via `Posix errno`), matching
 the return-code discipline of the rest of this file (MACVM has no exceptions)."
Object subclass: PosixFile [
    | fd |
    <classVars: Scratch>

    "── flag / mode / whence constants (Darwin, arm64) ──"
    PosixFile class >> oRdOnly [ ^0 ]
    PosixFile class >> oWrOnly [ ^1 ]
    PosixFile class >> oRdWr   [ ^2 ]
    PosixFile class >> oAppend [ ^8 ]
    PosixFile class >> oCreat  [ ^512 ]
    PosixFile class >> oTrunc  [ ^1024 ]
    PosixFile class >> oExcl   [ ^2048 ]
    PosixFile class >> seekSet [ ^0 ]
    PosixFile class >> seekCur [ ^1 ]
    PosixFile class >> seekEnd [ ^2 ]
    PosixFile class >> defaultMode [ ^420 ]     "0644"

    "One page, made once, reused (never munmap'd — like Posix scratch). Both
     the NUL-terminated path and the 4096-byte I/O chunks live here in turn."
    PosixFile class >> scratch [
        Scratch isNil ifTrue: [ Scratch := NativeBuffer page ].
        ^Scratch
    ]
    "Stage aString into `buf` as a NUL-terminated C string; answer its address
     (a SmallInteger for a #g pointer arg). Darwin PATH_MAX is 1024, so any
     path fits the 4096-byte page with room to spare."
    PosixFile class >> cStringOf: aString into: buf [
        | n |
        n := aString size.
        1 to: n do: [ :i | buf byteAt: i - 1 put: (aString basicByteAt: i) ].
        buf byteAt: n put: 0.
        ^buf address
    ]

    "── opening (answer an open PosixFile, or nil on failure) ──"
    PosixFile class >> open: aPath flags: fl [
        | rc |
        rc := Posix openPath: (self cStringOf: aPath into: self scratch) flags: fl.
        rc < 0 ifTrue: [ ^nil ].
        ^self basicNew setFd: rc
    ]
    PosixFile class >> openForRead: aPath [ ^self open: aPath flags: self oRdOnly ]
    PosixFile class >> createForWrite: aPath [
        ^self createForWrite: aPath mode: self defaultMode
    ]
    PosixFile class >> createForWrite: aPath mode: m [
        | rc |
        rc := Posix creatPath: (self cStringOf: aPath into: self scratch) mode: m.
        rc < 0 ifTrue: [ ^nil ].
        ^self basicNew setFd: rc
    ]

    setFd: anFd [ fd := anFd. ^self ]
    fd [ ^fd ]
    isOpen [ ^fd notNil and: [ fd >= 0 ] ]

    "── fd-level (caller owns the NativeBuffer) ──"
    readInto: aBuffer count: n [ ^Posix read: fd into: aBuffer address count: n ]
    writeFrom: aBuffer count: n [ ^Posix write: fd from: aBuffer address count: n ]
    seekTo: off from: whence [ ^Posix lseekFd: fd offset: off whence: whence ]
    "Size without stat: remember the cursor, seek to end, restore it."
    sizeInBytes [
        | cur end |
        cur := self seekTo: 0 from: self class seekCur.
        end := self seekTo: 0 from: self class seekEnd.
        self seekTo: cur from: self class seekSet.
        ^end
    ]
    close [ | rc | rc := Posix close: fd. fd := -1. ^rc ]

    "── whole-file, through the shared 4096-byte scratch page ──"
    "Read from the current offset to EOF; answer the bytes as a String (the
     file's bytes verbatim — treat them as the UTF-8 they already are)."
    readAll [
        | buf stream n chunk |
        buf := self class scratch.
        stream := WriteStream on: (String new: 0).
        [ n := self readInto: buf count: 4096. n > 0 ] whileTrue: [
            chunk := String new: n.
            1 to: n do: [ :i | chunk basicByteAt: i put: (buf byteAt: i - 1) ].
            stream nextPutAll: chunk ].
        ^stream contents
    ]
    "Write all of aString's bytes; answer the total moved (loops on the kernel's
     count, so a short write just continues from where it stopped)."
    writeAll: aString [
        | buf sz total len moved |
        buf := self class scratch.
        sz := aString size.
        total := 0.
        [ total < sz ] whileTrue: [
            len := (sz - total) min: 4096.
            1 to: len do: [ :i | buf byteAt: i - 1 put: (aString basicByteAt: total + i) ].
            moved := Posix write: fd from: buf address count: len.
            moved <= 0 ifTrue: [ ^total ].
            total := total + moved ].
        ^total
    ]

    "── class-side conveniences: open + act + close in one call ──"
    "Whole file -> String, or nil if it can't be opened."
    PosixFile class >> slurp: aPath [
        | f s |
        f := self openForRead: aPath.
        f isNil ifTrue: [ ^nil ].
        s := f readAll.
        f close.
        ^s
    ]
    "String -> whole file (created/truncated); answer bytes written, or nil if
     it can't be created."
    PosixFile class >> spit: aPath contents: aString [
        | f n |
        f := self createForWrite: aPath.
        f isNil ifTrue: [ ^nil ].
        n := f writeAll: aString.
        f close.
        ^n
    ]
    PosixFile class >> exists: aPath [
        | f |
        f := self openForRead: aPath.
        f isNil ifTrue: [ ^false ].
        f close.
        ^true
    ]
    PosixFile class >> delete: aPath [
        ^(Posix unlinkPath: (self cStringOf: aPath into: self scratch)) = 0
    ]
]
