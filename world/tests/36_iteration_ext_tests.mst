"36_iteration_ext_tests.mst — IterationExtTests: indexed-iteration + reduction
 protocol and the Interval>>reversed fix (world/55_iteration_ext.mst)."

TestCase subclass: IterationExtTests [
    runAll [
        self runTest: #testSumWith do: [ self testSumWith ].
        self runTest: #testFold do: [ self testFold ].
        self runTest: #testWithIndex do: [ self testWithIndex ].
        self runTest: #testIntervalReversed do: [ self testIntervalReversed ].
    ]

    testSumWith [
        self assert: (#(1 2 3 4) sum: [:x | x * x ]) = 30.
        self assert: (#() sum: [:x | x ]) = 0.
        self assert: (#(1 2 3) sum: [:x | 1 ]) = 3.
    ]

    testFold [
        self assert: (#(1 2 3 4) fold: [:a :b | a + b ]) = 10.
        self assert: (#(5) fold: [:a :b | a + b ]) = 5.
        self assert: (#(3 1 4 1 5) fold: [:a :b | a max: b ]) = 5.
    ]

    testWithIndex [
        | acc |
        self assert: (#(10 20 30) withIndexCollect: [:v :i | v + i ]) = #(11 22 33).
        self assert: (#(10 20 30) collectWithIndex: [:v :i | i ]) = #(1 2 3).
        "withIndexDo: passes (value, index)"
        acc := OrderedCollection new.
        #(9 8 7) withIndexDo: [:v :i | acc add: (i * 100) + v ].
        self assert: acc asArray = #(109 208 307).
    ]

    "Interval is immutable; reversed used to fail on it via at:put:."
    testIntervalReversed [
        self assert: (1 to: 5) reversed = #(5 4 3 2 1).
        self assert: (1 to: 5) reverse = #(5 4 3 2 1).
        self assert: (1 to: 10 by: 2) reversed = #(9 7 5 3 1).
        self assert: (2 to: 6) reversed first = 6.
    ]
]
