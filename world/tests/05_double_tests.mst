"05_double_tests.mst — DoubleTests (tests_s06.md '05 DoubleTests')."

TestCase subclass: DoubleTests [
    runAll [
        self runTest: #testArithLiterals do: [ self testArithLiterals ].
        self runTest: #testMixedCoercion do: [ self testMixedCoercion ].
        self runTest: #testMathOps do: [ self testMathOps ].
        self runTest: #testComparisons do: [ self testComparisons ].
        self runTest: #testPrintString do: [ self testPrintString ].
    ]

    testArithLiterals [
        self assert: 3.14 class == Double.
        self assert: 1e10 class == Double.
        self assert: (1.0 + 2.0) = 3.0.
        self assert: (3.0 - 1.0) = 2.0.
    ]
    testMixedCoercion [
        self assert: (1 + 2.5) = 3.5.
        self assert: (2.5 + 1) = 3.5.
        self assert: (1 + 2.5) class == Double.
        self assert: (2.5 + 1) class == Double.
    ]
    testMathOps [
        self assert: 9.0 sqrt = 3.0.
        self assert: 2.7 floor = 2.
        self assert: 2.7 ceiling = 3.
        self assert: 2.7 truncated = 2.
        self assert: -2.7 abs = 2.7.
        self assert: 2.7 negated = -2.7.
    ]
    testComparisons [
        self assert: 1 < 1.5.
        self deny: 1.5 < 1.
    ]
    testPrintString [
        self assert: 0.1 printString = '0.1'.
    ]
]
