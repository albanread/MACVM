"44_posix_io_tests.mst — PosixIoTests: the slice-A gate for POSIX I/O over
 the FFI (world/61_posix_io.mst, docs/asyncio_design.md). Everything here is
 headless and never leaves the machine — pipes, kqueue, and loopback-only
 TCP (bound to 127.0.0.1, ephemeral ports) — so it runs in the ordinary
 it_world gate with no firewall prompt. The tests prove, in order: signed
 returns cross the FFI, real bytes cross a real pipe, kqueue readiness (the
 foundation the IoWorker event loop stands on) reports exactly the right
 events, amounts, and EOF, the EVFILT_USER wake latches, and the TCP
 binding surface round-trips."

TestCase subclass: PosixIoTests [
    runAll [
        self runTest: #testNegativeReturnComesThrough do: [ self testNegativeReturnComesThrough ].
        self runTest: #testErrnoReadable do: [ self testErrnoReadable ].
        self runTest: #testPipeWriteRead do: [ self testPipeWriteRead ].
        self runTest: #testKqueueReadReadiness do: [ self testKqueueReadReadiness ].
        self runTest: #testKqueueWriteReadiness do: [ self testKqueueWriteReadiness ].
        self runTest: #testKqueueEofFlag do: [ self testKqueueEofFlag ].
        self runTest: #testUserEventTriggersAndLatches do: [ self testUserEventTriggersAndLatches ].
        self runTest: #testUserEventCrossHandlePoke do: [ self testUserEventCrossHandlePoke ].
        self runTest: #testTcpLoopbackRoundTrip do: [ self testTcpLoopbackRoundTrip ].
    ]

    "pipe() into the buffer head; answers {readFd. writeFd} (two u32s)."
    pipeOn: buf [
        | rc |
        rc := Posix pipeInto: buf address.
        self assert: rc = 0.
        ^Array with: (buf u32At: 0) with: (buf u32At: 4)
    ]

    "close(-1) answers -1: a negative ssize_t crosses the #g unmarshal as a
     negative SmallInteger, not a giant unsigned — everything downstream
     (read counts, kevent returns) relies on this."
    testNegativeReturnComesThrough [
        self assert: (Posix close: -1) = -1.
    ]

    "…and the matching errno is readable through __error(): EBADF = 9."
    testErrnoReadable [
        Posix close: -1.
        self assert: Posix errno = 9.
    ]

    testPipeWriteRead [
        | buf fds wrote got |
        buf := NativeBuffer page.
        fds := self pipeOn: buf.
        buf byteAt: 512 put: 65.
        buf byteAt: 513 put: 66.
        buf byteAt: 514 put: 67.
        wrote := Posix write: (fds at: 2) from: buf address + 512 count: 3.
        self assert: wrote = 3.
        got := Posix read: (fds at: 1) into: buf address + 600 count: 3.
        self assert: got = 3.
        self assert: (buf byteAt: 600) = 65.
        self assert: (buf byteAt: 601) = 66.
        self assert: (buf byteAt: 602) = 67.
        Posix close: (fds at: 1). Posix close: (fds at: 2).
    ]

    "The core readiness contract: nothing ready -> zero events; write 3
     bytes -> exactly one EVFILT_READ event carrying ident = the fd and
     data = 3 (the bounded-read amount); drain it -> zero events again."
    testKqueueReadReadiness [
        | kq buf fds events e |
        kq := Kqueue new.
        buf := kq buffer.
        fds := self pipeOn: buf.
        self assert: (kq watchRead: (fds at: 1)) = 0.

        events := kq pollMs: 0.
        self assert: events size = 0.

        buf byteAt: 512 put: 88.
        buf byteAt: 513 put: 89.
        buf byteAt: 514 put: 90.
        Posix write: (fds at: 2) from: buf address + 512 count: 3.

        events := kq pollMs: 200.
        self assert: events size = 1.
        e := events at: 1.
        self assert: (e at: 1) = (fds at: 1).   "ident = the watched fd"
        self assert: (e at: 2) = -1.            "EVFILT_READ"
        self assert: (e at: 3) = 3.             "data = readable byte count"

        "a read bounded by `data` cannot block, even on a blocking fd"
        self assert: (Posix read: (fds at: 1) into: buf address + 600 count: (e at: 3)) = 3.
        self assert: (buf byteAt: 600) = 88.

        events := kq pollMs: 0.
        self assert: events size = 0.

        Posix close: (fds at: 1). Posix close: (fds at: 2). kq close.
    ]

    "An empty pipe's write end is immediately writable, with data = the
     buffer space a bounded write may use."
    testKqueueWriteReadiness [
        | kq fds events e |
        kq := Kqueue new.
        fds := self pipeOn: kq buffer.
        self assert: (kq watchWrite: (fds at: 2)) = 0.
        events := kq pollMs: 200.
        self assert: events size = 1.
        e := events at: 1.
        self assert: (e at: 1) = (fds at: 2).
        self assert: (e at: 2) = -2.            "EVFILT_WRITE"
        self assert: (e at: 3) > 0.             "writable space"
        Posix close: (fds at: 1). Posix close: (fds at: 2). kq close.
    ]

    "EVFILT_USER — the kqueue-native user signal the IoWorker's wake rides
     on (world/62). The property under test is LATCHING: a trigger fired
     while nobody is polling is not lost — the next poll returns it — and
     EV_CLEAR resets it on delivery so it fires exactly once per trigger.
     (That no-lost-wakeup guarantee is what a raw POSIX signal cannot give
     kevent on Darwin, and why the wake is a user event, not pthread_kill.)"
    testUserEventTriggersAndLatches [
        | kq events e |
        kq := Kqueue new.
        self assert: kq registerUserEvent = 0.
        self assert: (kq pollMs: 0) size = 0.       "registered, not fired"
        self assert: kq triggerUserEvent = 0.       "fire with NO poller: latches"
        events := kq pollMs: 0.
        self assert: events size = 1.
        e := events at: 1.
        self assert: (e at: 1) = 0.                 "ident = the register ident"
        self assert: (e at: 2) = -10.               "EVFILT_USER"
        self assert: (kq pollMs: 0) size = 0.       "EV_CLEAR reset it on delivery"
        kq close.
    ]

    "The poke path exactly as the IoWorker uses it: a SECOND Kqueue handle
     wrapped around the SAME kernel kq fd (worker VMs share one fd table)
     triggers the user event, and the first handle's poll sees it — two
     NativeBuffer pages, one kernel object."
    testUserEventCrossHandlePoke [
        | kq poker events |
        kq := Kqueue new.
        kq registerUserEvent.
        poker := Kqueue onFd: kq fd.
        self assert: poker triggerUserEvent = 0.
        events := kq pollMs: 200.
        self assert: events size = 1.
        self assert: ((events at: 1) at: 2) = -10.
        kq close.
    ]

    "The whole TCP binding surface in one loopback round-trip: socket/bind
     (127.0.0.1:0 — ephemeral port, no firewall prompt)/listen, the bound
     port read back via getsockname, kqueue readiness ON THE LISTENER
     (data = pending-connection count — what makes a bounded accept safe),
     accept, and 3 real bytes client->server through a bounded read.
     Everything stays on-machine."
    testTcpLoopbackRoundTrip [
        | kq buf listener port client events e conn got |
        kq := Kqueue new.
        buf := kq buffer.
        listener := Posix tcpListenLoopback: 8.
        self assert: listener >= 0.
        port := Posix boundPortOf: listener.
        self assert: port > 0.
        self assert: (kq watchRead: listener) = 0.
        self assert: (kq pollMs: 0) size = 0.       "no one connecting yet"

        client := Posix tcpConnectLoopback: port.
        self assert: client >= 0.

        events := kq pollMs: 2000.
        self assert: events size = 1.
        e := events at: 1.
        self assert: (e at: 1) = listener.          "the listener went readable"
        self assert: (e at: 3) >= 1.                "data = pending connections"

        conn := Posix acceptOn: listener.
        self assert: conn >= 0.

        buf byteAt: 512 put: 80. buf byteAt: 513 put: 73. buf byteAt: 514 put: 71.
        self assert: (Posix write: client from: buf address + 512 count: 3) = 3.
        self assert: (kq watchRead: conn) = 0.
        events := kq pollMs: 2000.
        self assert: events size = 1.
        self assert: ((events at: 1) at: 1) = conn.
        self assert: ((events at: 1) at: 3) = 3.    "3 bytes ready on the accepted fd"
        got := Posix read: conn into: buf address + 600 count: 3.
        self assert: got = 3.
        self assert: (buf byteAt: 600) = 80.        "P"
        self assert: (buf byteAt: 601) = 73.        "I"
        self assert: (buf byteAt: 602) = 71.        "G"

        Posix close: client. Posix close: conn. Posix close: listener. kq close.
    ]

    "Closing the write end surfaces EV_EOF (32768, the u16 top bit — so
     `flags >= 32768` tests it without needing bitAnd:) on the read watch:
     how the IoWorker will distinguish 'peer gone' from 'no data yet'."
    testKqueueEofFlag [
        | kq fds events e |
        kq := Kqueue new.
        fds := self pipeOn: kq buffer.
        kq watchRead: (fds at: 1).
        Posix close: (fds at: 2).
        events := kq pollMs: 200.
        self assert: events size = 1.
        e := events at: 1.
        self assert: (e at: 1) = (fds at: 1).
        self assert: (e at: 4) >= 32768.        "EV_EOF set"
        Posix close: (fds at: 1). kq close.
    ]
]
