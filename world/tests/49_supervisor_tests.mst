"49_supervisor_tests.mst — the O0 gate (docs/otp_workers_design.md §7): the
 supervisor's ENTIRE decision logic proven single-VM with zero threads. Deaths
 are synthetic — either fed straight to SupervisorRegistry workerDied: (the
 exact call the onWorkerDied: hook makes) or, for the seam test, driven
 through the REAL Worker dispatchOne: with a genuinely-pickled
 {#workerDied. id} envelope (prims 227/228 are pure and need no worker role —
 the MOP-M0 fact). Spawning/terminating go through the spawnHook: test double
 (FakeWorkerHandle below), the clock through clockHook:, so intensity windows
 are deterministic and instant.

 Ordering matters once: testDiedFallsThroughWithoutSupervision runs FIRST,
 while Worker's DiedHandler is still nil (SupervisorRegistry installs it
 lazily on first registration and it then stays for the VM's life) — that is
 the compatibility half of the seam, pinning that unsupervised embeddings
 (embed.rs observes deaths via onReply:) keep today's behavior exactly."

"The spawnHook: test double: mints handles with increasing ids and records
 every spawn/terminate in one shared class-side log the assertions read."
Object subclass: FakeWorkerHandle [
    | id <Integer> |
    <classVars: Log NextId>

    FakeWorkerHandle class >> resetLog [
        Log := OrderedCollection new.
        NextId := 100
    ]
    FakeWorkerHandle class >> log ^ <OrderedCollection> [ ^Log ]
    FakeWorkerHandle class >> spawnedWith: initSource <String> ^ <FakeWorkerHandle> [
        NextId := NextId + 1.
        Log add: (Array with: #spawn with: NextId with: initSource).
        ^self basicNew setId: NextId
    ]
    setId: n <Integer> ^ <Self> [ id := n. ^self ]
    id ^ <Integer> [ ^id ]
    "Always alive: nothing in O0-O2 needed liveness, only identity+log."
    isAlive ^ <Boolean> [ ^true ]
    terminate ^ <Self> [
        Log add: (Array with: #terminate with: id).
        ^self
    ]
]

"A test double standing in for a REAL Worker handle in ServiceWorker's
 call:/cast: tests: WorkerNames-bindable (id/isAlive), plus a shared log
 recording every (peer, corr, payload) ServiceWorker's sendHook: routes
 here instead of a real primSend: — so these tests exercise ServiceWorker's
 OWN bookkeeping (deadline registration/cancellation/sweep/death-cross-
 check) with zero threads and zero real IPC, matching O0's posture."
Object subclass: FakeCallTarget [
    | id <Integer> alive <Boolean> |
    <classVars: SendLog>

    FakeCallTarget class >> resetSendLog [ SendLog := OrderedCollection new ]
    FakeCallTarget class >> sendLog ^ <OrderedCollection> [ ^SendLog ]
    FakeCallTarget class >> id: n <Integer> ^ <FakeCallTarget> [
        ^self basicNew setId: n
    ]
    setId: n <Integer> ^ <Self> [ id := n. alive := true. ^self ]
    id ^ <Integer> [ ^id ]
    isAlive ^ <Boolean> [ ^alive ]
    markDead [ alive := false ]
    send: aPayload <Object> [
        SendLog add: (Array with: #cast with: id with: aPayload)
    ]
]

"A hand-cranked monotonic clock for clockHook: — intensity windows advance
 exactly when a test says so."
Object subclass: FakeClock [
    <classVars: Now>
    FakeClock class >> reset [ Now := 1000000 ]
    FakeClock class >> now ^ <Integer> [ ^Now ]
    FakeClock class >> advanceBy: ms <Integer> [ Now := Now + ms ]
]

TestCase subclass: SupervisorTests [
    runAll [
        self runTest: #testDiedFallsThroughWithoutSupervision do: [ self testDiedFallsThroughWithoutSupervision ].
        self runTest: #testStartSpawnsInOrderAndBindsNames do: [ self testStartSpawnsInOrderAndBindsNames ].
        self runTest: #testChildDeathRestartsAndRebindsName do: [ self testChildDeathRestartsAndRebindsName ].
        self runTest: #testTemporaryChildIsNotRestarted do: [ self testTemporaryChildIsNotRestarted ].
        self runTest: #testIntensityGivesUpAtExactlyMaxPlusOne do: [ self testIntensityGivesUpAtExactlyMaxPlusOne ].
        self runTest: #testRestartsOutsideWindowAgeOut do: [ self testRestartsOutsideWindowAgeOut ].
        self runTest: #testStopTerminatesInReverseOrderAndSilences do: [ self testStopTerminatesInReverseOrderAndSilences ].
        self runTest: #testDiedSeamRoutesThroughDispatchOne do: [ self testDiedSeamRoutesThroughDispatchOne ].
        self runTest: #testUnsupervisedDeathIsIgnoredByRegistry do: [ self testUnsupervisedDeathIsIgnoredByRegistry ].
        self runTest: #testOneForAllRestartsEverySibling do: [ self testOneForAllRestartsEverySibling ].
        self runTest: #testRestForOneRestartsOnlyTheSuffix do: [ self testRestForOneRestartsOnlyTheSuffix ].
        self runTest: #testRestForOneAtLastPositionIsLocal do: [ self testRestForOneAtLastPositionIsLocal ].
        self runTest: #testOneForAllSkipsTemporaryOnRestart do: [ self testOneForAllSkipsTemporaryOnRestart ].
        self runTest: #testChildSupervisorGiveUpEscalatesAndRestartsFresh do: [ self testChildSupervisorGiveUpEscalatesAndRestartsFresh ].
        self runTest: #testEscalationStormGivesUpAtRoot do: [ self testEscalationStormGivesUpAtRoot ].
        self runTest: #testTreeStartStopOrdering do: [ self testTreeStartStopOrdering ].
        self runTest: #testServiceWorkerCastDelegatesToTheNamedTarget do: [ self testServiceWorkerCastDelegatesToTheNamedTarget ].
        self runTest: #testServiceWorkerCallNormalReplyCancelsTheDeadline do: [ self testServiceWorkerCallNormalReplyCancelsTheDeadline ].
        self runTest: #testServiceWorkerCallRpcErrorShapedReplyFunnelsToOnError do: [ self testServiceWorkerCallRpcErrorShapedReplyFunnelsToOnError ].
        self runTest: #testServiceWorkerCallUnboundOrDeadNameFailsFastSynchronously do: [ self testServiceWorkerCallUnboundOrDeadNameFailsFastSynchronously ].
        self runTest: #testServiceWorkerSweepFiresTimeoutNotBeforeDeadline do: [ self testServiceWorkerSweepFiresTimeoutNotBeforeDeadline ].
        self runTest: #testServiceWorkerDeathCrossCheckFailsFastAndSuppressesLateReply do: [ self testServiceWorkerDeathCrossCheckFailsFastAndSuppressesLateReply ].
        self runTest: #testServiceWorkerNoLeakOverManyMixedOutcomes do: [ self testServiceWorkerNoLeakOverManyMixedOutcomes ].
        self runTest: #testAfterRestartFiresOnEveryStartWithTheFreshHandle do: [ self testAfterRestartFiresOnEveryStartWithTheFreshHandle ].
        self cleanupHooks
    ]

    "── shared setup/teardown ─────────────────────────────────────────────"
    freshTree [
        FakeWorkerHandle resetLog.
        FakeClock reset.
        WorkerNames reset.
        SupervisorRegistry reset.
        WorkerSupervisor spawnHook: [:src | FakeWorkerHandle spawnedWith: src ].
        WorkerSupervisor clockHook: [ FakeClock now ]
    ]
    cleanupHooks [
        WorkerSupervisor spawnHook: nil.
        WorkerSupervisor clockHook: nil
    ]
    "The synthetic death: exactly the call the onWorkerDied: hook makes."
    kill: aName [
        SupervisorRegistry workerDied: (WorkerNames named: aName) id
    ]
    spawnCount ^ <Integer> [
        ^FakeWorkerHandle log count: [:e | (e at: 1) == #spawn ]
    ]
    terminateLog ^ <OrderedCollection> [
        ^FakeWorkerHandle log select: [:e | (e at: 1) == #terminate ]
    ]
    spawnLog ^ <OrderedCollection> [
        ^FakeWorkerHandle log select: [:e | (e at: 1) == #spawn ]
    ]

    "── 1. compatibility: no supervision, no behavior change ──────────────
     MUST run before any test registers a child (DiedHandler still nil): a
     {#workerDied. id} envelope pushed through the REAL dispatchOne: falls
     through to the general onReply: handler, exactly as before this slice."
    testDiedFallsThroughWithoutSupervision [
        | seen env |
        seen := OrderedCollection new.
        Worker onReply: [:m | m isWorkerDied ifTrue: [ seen add: (m payload at: 2) ] ].
        env := Array with: 7 with: 0
                     with: (Worker pickle: (Array with: #workerDied with: 7)).
        Worker dispatchOne: env.
        Worker onReply: nil.
        self assert: seen size equals: 1.
        self assert: (seen first) equals: 7
    ]

    "── 2. start: spawn order + names ─────────────────────────────────────"
    testStartSpawnsInOrderAndBindsNames [
        | sup log |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #oneForOne.
        sup superviseNamed: #a init: 'initA'.
        sup superviseNamed: #b init: 'initB'.
        sup start.
        self assert: sup state equals: #running.
        log := FakeWorkerHandle log.
        self assert: self spawnCount equals: 2.
        self assert: ((log at: 1) at: 3) equals: 'initA'.   "declared order"
        self assert: ((log at: 2) at: 3) equals: 'initB'.
        self assert: (WorkerNames named: #a) notNil.
        self assert: (WorkerNames named: #b) notNil.
        self assert: (WorkerNames named: #a) id equals: 101.
        self assert: (WorkerNames named: #nosuch) isNil.
        sup stop
    ]

    "── 3. one death, one restart, name rebound ───────────────────────────"
    testChildDeathRestartsAndRebindsName [
        | sup oldId newHandle |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #oneForOne.
        sup superviseNamed: #a init: 'initA'.
        sup superviseNamed: #b init: 'initB'.
        sup start.
        oldId := (WorkerNames named: #a) id.
        self kill: #a.
        self assert: sup state equals: #running.
        self assert: self spawnCount equals: 3.             "2 starts + 1 restart"
        newHandle := WorkerNames named: #a.
        self assert: newHandle notNil.
        self deny: newHandle id = oldId.                     "a FRESH worker"
        self assert: (WorkerNames named: #b) id equals: 102. "sibling untouched (#oneForOne)"
        "the restart re-used the spec's stored init source (the raw log's
         3rd entry is now the corpse's defensive terminate, so filter)"
        self assert: ((self spawnLog at: 3) at: 3) equals: 'initA'.
        sup stop
    ]

    "── 4. #temporary: cleared, never restarted, no intensity charge ──────"
    testTemporaryChildIsNotRestarted [
        | sup |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #oneForOne.
        sup superviseNamed: #t init: 'initT' restart: #temporary.
        sup superviseNamed: #p init: 'initP'.
        sup start.
        self kill: #t.
        self assert: self spawnCount equals: 2.              "no respawn"
        self assert: (WorkerNames named: #t) isNil.          "name cleared"
        self assert: sup state equals: #running.
        "a #temporary death charges nothing: the #permanent sibling still has
         its full window (maxRestarts kills all restart, no give-up)"
        self kill: #p. self kill: #p. self kill: #p.
        self assert: sup state equals: #running.
        self assert: self spawnCount equals: 5.
        sup stop
    ]

    "── 5. intensity: gives up at exactly maxRestarts+1 in the window ─────"
    testIntensityGivesUpAtExactlyMaxPlusOne [
        | sup |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #oneForOne.
        sup maxRestarts: 3 perSeconds: 5.
        sup superviseNamed: #a init: 'initA'.
        sup superviseNamed: #b init: 'initB'.
        sup start.
        "maxRestarts deaths all restart (clock never advances: same window)"
        self kill: #a. self kill: #a. self kill: #a.
        self assert: sup state equals: #running.
        self assert: self spawnCount equals: 5.              "2 starts + 3 restarts"
        "the (max+1)th death within the window trips give-up"
        self kill: #a.
        self assert: sup state equals: #givenUp.
        self assert: self spawnCount equals: 5.              "NO 4th restart"
        "terminates: every childDied: first retires the corpse handle
         defensively (the duplicate-died/reused-id guard — a no-op on a
         genuinely dead worker, load-bearing on a stale notice), so the four
         kills log a's successive incarnations 101/103/104/105; give-up then
         tears the survivors down in REVERSE start order — b (102) last,
         a's spec already cleared"
        self assert: self terminateLog size equals: 5.
        self assert: ((self terminateLog at: 1) at: 2) equals: 101.
        self assert: ((self terminateLog at: 2) at: 2) equals: 103.
        self assert: ((self terminateLog at: 3) at: 2) equals: 104.
        self assert: ((self terminateLog at: 4) at: 2) equals: 105.
        self assert: ((self terminateLog at: 5) at: 2) equals: 102.
        self assert: (WorkerNames named: #a) isNil.
        self assert: (WorkerNames named: #b) isNil.
        "a straggler death after give-up changes nothing"
        SupervisorRegistry workerDied: 999.
        self assert: sup state equals: #givenUp
    ]

    "── 6. the window ages out: spaced crashes never give up ──────────────"
    testRestartsOutsideWindowAgeOut [
        | sup n |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #oneForOne.
        sup maxRestarts: 3 perSeconds: 5.
        sup superviseNamed: #a init: 'initA'.
        sup start.
        "10 crashes, each 6s apart (> the 5s window): every one restarts"
        n := 0.
        [ n < 10 ] whileTrue: [
            FakeClock advanceBy: 6000.
            self kill: #a.
            n := n + 1 ].
        self assert: sup state equals: #running.
        self assert: self spawnCount equals: 11.             "1 start + 10 restarts"
        sup stop
    ]

    "── 7. stop: reverse order, names unbound, deaths-after-stop inert ────"
    testStopTerminatesInReverseOrderAndSilences [
        | sup deadId |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #oneForOne.
        sup superviseNamed: #a init: 'initA'.
        sup superviseNamed: #b init: 'initB'.
        sup superviseNamed: #c init: 'initC'.
        sup start.
        deadId := (WorkerNames named: #a) id.
        sup stop.
        self assert: sup state equals: #idle.
        self assert: self terminateLog size equals: 3.
        self assert: ((self terminateLog at: 1) at: 2) equals: 103.   "c first"
        self assert: ((self terminateLog at: 2) at: 2) equals: 102.   "then b"
        self assert: ((self terminateLog at: 3) at: 2) equals: 101.   "then a"
        self assert: (WorkerNames named: #a) isNil.
        self assert: (WorkerNames named: #b) isNil.
        self assert: (WorkerNames named: #c) isNil.
        "a late death notice for a stopped child is unowned -> logged, inert"
        SupervisorRegistry workerDied: deadId.
        self assert: sup state equals: #idle.
        self assert: self spawnCount equals: 3
    ]

    "── 8. the seam end to end: a real pickled death through dispatchOne: ─"
    testDiedSeamRoutesThroughDispatchOne [
        | sup deadId env |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #oneForOne.
        sup superviseNamed: #a init: 'initA'.
        sup start.
        deadId := (WorkerNames named: #a) id.
        "the wire shape workers.rs::died_envelope produces, genuinely pickled"
        env := Array with: deadId with: 0
                     with: (Worker pickle: (Array with: #workerDied with: deadId)).
        Worker dispatchOne: env.
        self assert: self spawnCount equals: 2.              "restart happened"
        self assert: (WorkerNames named: #a) notNil.
        self deny: (WorkerNames named: #a) id = deadId.
        sup stop
    ]

    "── 9. deaths nobody owns are logged and dropped ──────────────────────"
    testUnsupervisedDeathIsIgnoredByRegistry [
        | sup |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #oneForOne.
        sup superviseNamed: #a init: 'initA'.
        sup start.
        SupervisorRegistry workerDied: 424242.
        self assert: sup state equals: #running.             "tree untouched"
        self assert: self spawnCount equals: 1.
        self assert: (WorkerNames named: #a) notNil.
        sup stop
    ]

    "── 10. #oneForAll: one death restarts the whole set (O2) ─────────────
     Teardown of the survivors runs in REVERSE start order, the restart in
     declared order, and the whole cycle charges intensity ONCE."
    testOneForAllRestartsEverySibling [
        | sup |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #oneForAll.
        sup superviseNamed: #a init: 'initA'.
        sup superviseNamed: #b init: 'initB'.
        sup superviseNamed: #c init: 'initC'.
        sup start.                                            "101 102 103"
        self kill: #b.
        "childDied first retires b's corpse (102), then the strategy tears
         down the survivors reverse (c=103, a=101) and restarts a' b' c'"
        self assert: self terminateLog size equals: 3.
        self assert: ((self terminateLog at: 1) at: 2) equals: 102.
        self assert: ((self terminateLog at: 2) at: 2) equals: 103.
        self assert: ((self terminateLog at: 3) at: 2) equals: 101.
        self assert: self spawnCount equals: 6.               "3 starts + 3 restarts"
        self assert: (WorkerNames named: #a) id equals: 104.
        self assert: (WorkerNames named: #b) id equals: 105.
        self assert: (WorkerNames named: #c) id equals: 106.
        self assert: sup restartCount equals: 1.              "ONE charge, not three"
        self assert: sup state equals: #running.
        sup stop
    ]

    "── 11. #restForOne: only the dead child and its successors (O2) ──────"
    testRestForOneRestartsOnlyTheSuffix [
        | sup |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #restForOne.
        sup superviseNamed: #a init: 'initA'.
        sup superviseNamed: #b init: 'initB'.
        sup superviseNamed: #c init: 'initC'.
        sup start.                                            "101 102 103"
        self kill: #b.
        "suffix = b,c: corpse 102, then c=103 torn down; b'=104 c'=105"
        self assert: (WorkerNames named: #a) id equals: 101.  "a UNTOUCHED"
        self assert: (WorkerNames named: #b) id equals: 104.
        self assert: (WorkerNames named: #c) id equals: 105.
        self assert: sup restartCount equals: 1.
        "a death at position 1 restarts everything (the suffix is the set)"
        self kill: #a.
        self assert: (WorkerNames named: #a) id equals: 106.
        self assert: (WorkerNames named: #b) id equals: 107.
        self assert: (WorkerNames named: #c) id equals: 108.
        self assert: sup restartCount equals: 2.
        self assert: sup state equals: #running.
        sup stop
    ]

    "── 12. #restForOne at the LAST position degenerates to oneForOne ─────"
    testRestForOneAtLastPositionIsLocal [
        | sup |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #restForOne.
        sup superviseNamed: #a init: 'initA'.
        sup superviseNamed: #b init: 'initB'.
        sup superviseNamed: #c init: 'initC'.
        sup start.                                            "101 102 103"
        self kill: #c.
        self assert: (WorkerNames named: #a) id equals: 101.
        self assert: (WorkerNames named: #b) id equals: 102.
        self assert: (WorkerNames named: #c) id equals: 104.
        self assert: self terminateLog size equals: 1.        "only c's corpse"
        self assert: sup restartCount equals: 1.
        sup stop
    ]

    "── 13. a strategy teardown removes #temporary children for good ──────
     (OTP: temporary children are never restarted; only a full stop+start
     cycle re-creates them.)"
    testOneForAllSkipsTemporaryOnRestart [
        | sup |
        self freshTree.
        sup := WorkerSupervisor named: #svc strategy: #oneForAll.
        sup superviseNamed: #a init: 'initA'.
        sup superviseNamed: #t init: 'initT' restart: #temporary.
        sup superviseNamed: #c init: 'initC'.
        sup start.                                            "101 102 103"
        self kill: #a.
        "teardown reverse: c=103, t=102, a's corpse already cleared (101
         retired defensively first); restart: a'=104, t SKIPPED, c'=105"
        self assert: (WorkerNames named: #a) id equals: 104.
        self assert: (WorkerNames named: #t) isNil.
        self assert: (WorkerNames named: #c) id equals: 105.
        self assert: self spawnCount equals: 5.
        "a FULL stop+start cycle re-creates the temporary"
        sup stop.
        sup start.                                            "106 107 108"
        self assert: (WorkerNames named: #t) notNil.
        self assert: (WorkerNames named: #t) id equals: 107.
        sup stop
    ]

    "── 14. escalation: a giving-up child supervisor is restarted by its
     parent, with a FRESH intensity window (O2 trees) ─────────────────────"
    testChildSupervisorGiveUpEscalatesAndRestartsFresh [
        | par sub |
        self freshTree.
        par := WorkerSupervisor named: #par strategy: #oneForOne.
        sub := (WorkerSupervisor named: #sub strategy: #oneForOne)
            maxRestarts: 1 perSeconds: 5.
        sub superviseNamed: #x init: 'initX'.
        par superviseNamed: #w init: 'initW'.
        par superviseSupervisor: sub.
        par start.                                            "w=101, x=102"
        self kill: #x.                                        "sub restarts: x'=103"
        self assert: sub restartCount equals: 1.
        self kill: #x.
        "sub's window (1 in 5) is spent: it gives up and ESCALATES; the
         parent treats that as a child death and restarts the subtree"
        self assert: sub state equals: #running.              "already restarted"
        self assert: par restartCount equals: 1.
        self assert: sub restartCount equals: 0.              "FRESH window"
        self assert: (WorkerNames named: #x) id equals: 104.
        self assert: (WorkerNames named: #w) id equals: 101.  "sibling untouched"
        self assert: par state equals: #running.
        par stop
    ]

    "── 15. an escalation storm exhausts the parent too: root gives up and
     stays down ──────────────────────────────────────────────────────────"
    testEscalationStormGivesUpAtRoot [
        | par sub |
        self freshTree.
        par := (WorkerSupervisor named: #par strategy: #oneForOne)
            maxRestarts: 1 perSeconds: 5.
        sub := (WorkerSupervisor named: #sub strategy: #oneForOne)
            maxRestarts: 1 perSeconds: 5.
        sub superviseNamed: #x init: 'initX'.
        par superviseNamed: #w init: 'initW'.
        par superviseSupervisor: sub.
        par start.                                            "w=101, x=102"
        self kill: #x.                                        "sub charge 1, x'=103"
        self kill: #x.                                        "sub gives up -> par charge 1, sub fresh, x''=104"
        self assert: par restartCount equals: 1.
        self kill: #x.                                        "sub charge 1, x'''=105"
        self kill: #x.
        "sub gives up AGAIN; the parent's own window (1 in 5) is spent ->
         the ROOT gives up: everything down, in reverse (w torn down last)"
        self assert: par state equals: #givenUp.
        self assert: sub state equals: #idle.                 "stopped by the parent teardown"
        self assert: (WorkerNames named: #w) isNil.
        self assert: (WorkerNames named: #x) isNil.
        self assert: ((self terminateLog at: (self terminateLog size)) at: 2) equals: 101.
        "straggler deaths after the root give-up are inert"
        SupervisorRegistry workerDied: 999.
        self assert: par state equals: #givenUp
    ]

    "── 16. tree lifecycle ordering: a sub-supervisor holds an ordinary
     position — its children start inside it and stop in reverse ──────────"
    testTreeStartStopOrdering [
        | par sub |
        self freshTree.
        par := WorkerSupervisor named: #par strategy: #oneForOne.
        sub := WorkerSupervisor named: #sub strategy: #oneForOne.
        sub superviseNamed: #x init: 'initX'.
        par superviseNamed: #w1 init: 'initW1'.
        par superviseSupervisor: sub.
        par superviseNamed: #w2 init: 'initW2'.
        par start.
        "start order: w1, then the subtree (x), then w2"
        self assert: ((self spawnLog at: 1) at: 3) equals: 'initW1'.
        self assert: ((self spawnLog at: 2) at: 3) equals: 'initX'.
        self assert: ((self spawnLog at: 3) at: 3) equals: 'initW2'.
        par stop.
        "stop order: exact reverse -- w2, the subtree (x), w1"
        self assert: self terminateLog size equals: 3.
        self assert: ((self terminateLog at: 1) at: 2) equals: 103.   "w2"
        self assert: ((self terminateLog at: 2) at: 2) equals: 102.   "x"
        self assert: ((self terminateLog at: 3) at: 2) equals: 101.   "w1"
    ]

    "── O3: ServiceWorker + the deadline/death funnel ──────────────────────
     freshServiceWorker's sendHook: reroutes ServiceWorker's OWN send step
     into FakeCallTarget's log (no primitives touched), but registerReply:/
     dispatchOne:/PendingReplies are all the REAL Worker machinery — a
     synthetic reply is delivered by building a genuinely-pickled envelope
     and driving Worker dispatchOne: directly, exactly O0's seam-test
     pattern, so these tests exercise real corr-keyed routing end to end."
    freshServiceWorker [
        ServiceWorker reset.
        ServiceWorker sendHook: [:peer :corr :payload |
            FakeCallTarget sendLog add: (Array with: #call with: peer with: corr with: payload) ].
        FakeCallTarget resetSendLog.
        WorkerNames reset.
        FakeClock reset.
        WorkerSupervisor clockHook: [ FakeClock now ].   "SHARED clock -- ServiceWorker reads it too"
    ]
    cleanupServiceWorkerHooks [
        ServiceWorker sendHook: nil.
        WorkerSupervisor clockHook: nil
    ]
    "Build the synthetic reply envelope for a call: 's own answered corr,
     and drive it through the REAL dispatchOne: — the exact wire shape a
     genuine worker reply arrives as."
    deliverReplyFrom: peer <Integer> corr: c <Integer> payload: aPayload <Object> [
        Worker dispatchOne: (Array with: peer with: c with: (Worker pickle: aPayload))
    ]

    "── 17. cast: delegates straight to the named target's send: ──────────"
    testServiceWorkerCastDelegatesToTheNamedTarget [
        | svc target |
        self freshServiceWorker.
        target := FakeCallTarget id: 500.
        WorkerNames bind: #echoSvc to: target.
        svc := ServiceWorker named: #echoSvc.
        svc cast: #(recompute 10000).
        self assert: FakeCallTarget sendLog size equals: 1.
        self assert: ((FakeCallTarget sendLog first) at: 3) equals: #(recompute 10000).
        "an unbound name has nothing to send to -- silently"
        (ServiceWorker named: #nosuch) cast: #ignored.
        self assert: FakeCallTarget sendLog size equals: 1.
        self cleanupServiceWorkerHooks
    ]

    "── 18. a normal reply cancels the deadline before onReply: runs ───────"
    testServiceWorkerCallNormalReplyCancelsTheDeadline [
        | svc target c reply errored |
        self freshServiceWorker.
        target := FakeCallTarget id: 501.
        WorkerNames bind: #echoSvc to: target.
        svc := ServiceWorker named: #echoSvc.
        reply := nil. errored := false.
        c := svc call: #(primesBelow 100) timeoutMs: 5000
            onReply: [:r | reply := r]
            onError: [:e | errored := true].
        self assert: c > 0.
        self assert: ServiceWorker liveDeadlineCount equals: 1.
        self deliverReplyFrom: 501 corr: c payload: #(2 3 5 7).
        self assert: reply equals: #(2 3 5 7).
        self deny: errored.
        self assert: ServiceWorker liveDeadlineCount equals: 0.       "cancelled, not just answered"
        "sweeping well past any deadline must NOT also fire onError: --
         the cancelled entry is truly gone, not merely due-but-skipped"
        FakeClock advanceBy: 999999.
        ServiceWorker sweepDeadlines.
        self deny: errored.
        self cleanupServiceWorkerHooks
    ]

    "── 19. an {#rpcError. why} shaped reply funnels to onError:, not onReply: ──"
    testServiceWorkerCallRpcErrorShapedReplyFunnelsToOnError [
        | svc target c reply error |
        self freshServiceWorker.
        target := FakeCallTarget id: 502.
        WorkerNames bind: #echoSvc to: target.
        svc := ServiceWorker named: #echoSvc.
        reply := nil. error := nil.
        c := svc call: #(bogus) timeoutMs: 5000
            onReply: [:r | reply := r]
            onError: [:e | error := e].
        self deliverReplyFrom: 502 corr: c payload: (Array with: #rpcError with: 'no such class').
        self assert: reply isNil.
        self assert: error equals: 'no such class'.
        self cleanupServiceWorkerHooks
    ]

    "── 20. an unbound OR already-dead name fails fast, SYNCHRONOUSLY --
     no send attempted, no deadline ever registered ─────────────────────"
    testServiceWorkerCallUnboundOrDeadNameFailsFastSynchronously [
        | svc target error |
        self freshServiceWorker.
        error := nil.
        (ServiceWorker named: #nosuch) call: #(x) timeoutMs: 1000
            onReply: [:r | self assert: false]
            onError: [:e | error := e].
        self assert: error equals: #workerDied.
        self assert: FakeCallTarget sendLog isEmpty.
        self assert: ServiceWorker liveDeadlineCount equals: 0.
        target := FakeCallTarget id: 503.
        target markDead.
        WorkerNames bind: #deadSvc to: target.
        error := nil.
        svc := ServiceWorker named: #deadSvc.
        svc call: #(x) timeoutMs: 1000
            onReply: [:r | self assert: false]
            onError: [:e | error := e].
        self assert: error equals: #workerDied.
        self assert: FakeCallTarget sendLog isEmpty.
        self cleanupServiceWorkerHooks
    ]

    "── 21. the sweep fires #timeout exactly at (not before) the deadline,
     and never again for the same call ───────────────────────────────────"
    testServiceWorkerSweepFiresTimeoutNotBeforeDeadline [
        | svc target c error errorCount |
        self freshServiceWorker.
        target := FakeCallTarget id: 504.
        WorkerNames bind: #echoSvc to: target.
        svc := ServiceWorker named: #echoSvc.
        error := nil. errorCount := 0.
        c := svc call: #(slow) timeoutMs: 1000
            onReply: [:r | self assert: false]
            onError: [:e | error := e. errorCount := errorCount + 1].
        self assert: ServiceWorker liveDeadlineCount equals: 1.
        "well before the deadline: must NOT fire"
        FakeClock advanceBy: 500.
        ServiceWorker sweepDeadlines.
        self assert: error isNil.
        self assert: ServiceWorker liveDeadlineCount equals: 1.
        "past the deadline: fires exactly once"
        FakeClock advanceBy: 600.
        ServiceWorker sweepDeadlines.
        self assert: error equals: #timeout.
        self assert: errorCount equals: 1.
        self assert: ServiceWorker liveDeadlineCount equals: 0.
        "a second sweep, and a late-arriving reply, must both be silent"
        ServiceWorker sweepDeadlines.
        self deliverReplyFrom: 504 corr: c payload: #tooLate.
        self assert: errorCount equals: 1.
        self cleanupServiceWorkerHooks
    ]

    "── 22. the death cross-check fails every in-flight call to that peer
     immediately, and suppresses whatever late reply might still arrive ──"
    testServiceWorkerDeathCrossCheckFailsFastAndSuppressesLateReply [
        | svc target c1 c2 err1 err2 reply2 |
        self freshServiceWorker.
        target := FakeCallTarget id: 505.
        WorkerNames bind: #echoSvc to: target.
        svc := ServiceWorker named: #echoSvc.
        err1 := nil. err2 := nil. reply2 := nil.
        c1 := svc call: #(a) timeoutMs: 5000 onReply: [:r | self assert: false] onError: [:e | err1 := e].
        c2 := svc call: #(b) timeoutMs: 5000 onReply: [:r | reply2 := r] onError: [:e | err2 := e].
        self assert: ServiceWorker liveDeadlineCount equals: 2.
        ServiceWorker failPendingCallsTo: 505.
        self assert: err1 equals: #workerDied.
        self assert: err2 equals: #workerDied.
        self assert: ServiceWorker liveDeadlineCount equals: 0.
        "a reply that somehow still arrives after the death notice is inert"
        self deliverReplyFrom: 505 corr: c1 payload: #ghost.
        self deliverReplyFrom: 505 corr: c2 payload: #ghost.
        self assert: reply2 isNil.
        self cleanupServiceWorkerHooks
    ]

    "── 23. no leak: a mix of normal/timeout/died outcomes across many
     calls always returns liveDeadlineCount to exactly 0 ────────────────"
    testServiceWorkerNoLeakOverManyMixedOutcomes [
        | svc target n |
        self freshServiceWorker.
        target := FakeCallTarget id: 506.
        WorkerNames bind: #echoSvc to: target.
        svc := ServiceWorker named: #echoSvc.
        n := 60.
        1 to: n do: [:i |
            | c m |
            m := i \\ 3.
            c := svc call: i timeoutMs: 1000 onReply: [:r | ] onError: [:e | ].
            m = 0 ifTrue: [ self deliverReplyFrom: 506 corr: c payload: i ].
            "m = 1 -> left to time out; m = 2 -> left to die below" ].
        self assert: ServiceWorker liveDeadlineCount equals: (n * 2 / 3).  "1/3 answered already"
        FakeClock advanceBy: 2000.
        ServiceWorker sweepDeadlines.          "retires every m=1 AND every m=2 (all overdue)"
        self assert: ServiceWorker liveDeadlineCount equals: 0.
        "failPendingCallsTo: after everything already settled is a no-op,
         not a re-fire -- nothing left to retire"
        ServiceWorker failPendingCallsTo: 506.
        self assert: ServiceWorker liveDeadlineCount equals: 0.
        self cleanupServiceWorkerHooks
    ]

    "── 24. afterRestart: fires on EVERY (re)start, first and subsequent,
     each time with that start's fresh worker handle (IoWorker adoption,
     docs/otp_workers_design.md §6) ───────────────────────────────────────"
    testAfterRestartFiresOnEveryStartWithTheFreshHandle [
        | sup seen |
        self freshTree.
        seen := OrderedCollection new.
        sup := WorkerSupervisor named: #svc strategy: #oneForOne.
        sup superviseNamed: #io init: 'initIo' afterRestart: [:w | seen add: w id ].
        sup start.
        self assert: seen size equals: 1.
        self assert: seen first equals: 101.
        self kill: #io.
        self assert: seen size equals: 2.
        self assert: seen last equals: 102.
        self deny: (seen first = seen last).
        sup stop
    ]
]
