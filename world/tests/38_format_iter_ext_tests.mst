"38_format_iter_ext_tests.mst — FormatIterExtTests: number formatting + collection
 extras + Fraction rounding (world/57_format_iter_ext.mst)."

TestCase subclass: FormatIterExtTests [
    runAll [
        self runTest: #testRoundTo do: [ self testRoundTo ].
        self runTest: #testPadded do: [ self testPadded ].
        self runTest: #testRadix do: [ self testRadix ].
        self runTest: #testFractionRounding do: [ self testFractionRounding ].
        self runTest: #testFlatCollect do: [ self testFlatCollect ].
        self runTest: #testDetectMaxMin do: [ self testDetectMaxMin ].
        self runTest: #testGroupBy do: [ self testGroupBy ].
        self runTest: #testReplaceAll do: [ self testReplaceAll ].
        self runTest: #testOrderedExtras do: [ self testOrderedExtras ].
    ]

    testRoundTo [
        self assert: (3.14159 roundTo: 0.01) = 3.14.
        self assert: (17 roundTo: 5) = 15.
        self assert: (13 roundTo: 5) = 15.
        self assert: (12 roundTo: 5) = 10.
    ]

    testPadded [
        self assert: (5 printPaddedWith: $0 to: 3) = '005'.
        self assert: (123 printPaddedWith: $0 to: 2) = '123'.
        self assert: (42 printPaddedWith: $  to: 5) = '   42'.
    ]

    testRadix [
        self assert: (255 printString: 16) = 'ff'.
        self assert: (17 printString: 2) = '10001'.
        self assert: (0 printString: 2) = '0'.
        self assert: ((0 - 10) printString: 2) = '-1010'.
        self assert: (255 printString: 8) = '377'.
    ]

    testFractionRounding [
        self assert: (3/4) floor = 0.
        self assert: (3/4) ceiling = 1.
        self assert: (3/4) rounded = 1.
        self assert: (7/2) rounded = 4.
        self assert: (17/5) rounded = 3.
        self assert: (1/4) rounded = 0.
        self assert: ((0 - 3)/4) floor = -1.
        self assert: ((0 - 3)/4) rounded = -1.
    ]

    testFlatCollect [
        self assert: (#(1 2 3) flatCollect: [:x | Array with: x with: (x * 10) ]) = #(1 10 2 20 3 30).
        self assert: (#() flatCollect: [:x | x ]) = #().
    ]

    testDetectMaxMin [
        self assert: (#(3 1 4 1 5) detectMax: [:x | x ]) = 5.
        self assert: (#('aa' 'b' 'ccc') detectMax: [:s | s size ]) = 'ccc'.
        self assert: (#('aa' 'b' 'ccc') detectMin: [:s | s size ]) = 'b'.
    ]

    testGroupBy [
        | g |
        g := #(1 2 3 4 5 6) groupBy: [:x | x even ].
        self assert: (g at: true) asArray = #(2 4 6).
        self assert: (g at: false) asArray = #(1 3 5).
    ]

    testReplaceAll [
        self assert: ((Array withAll: #(1 2 2 3 2)) replaceAll: 2 with: 9) = #(1 9 9 3 9).
    ]

    testOrderedExtras [
        | oc |
        oc := OrderedCollection withAll: #(3 4).
        oc addAllFirst: #(1 2).
        self assert: oc asArray = #(1 2 3 4).
        self assert: ((OrderedCollection withAll: #(1 2 3 4 5)) removeFirst: 2) asArray = #(1 2).
        self assert: ((OrderedCollection withAll: #(1 2 3 4 5)) removeLast: 2) asArray = #(5 4).
    ]
]
