"07_string_tests.mst — StringTests (tests_s06.md '07 StringTests')."

Object subclass: StringTestsAliasHelper [
    StringTestsAliasHelper class >> lit [
        ^'abc'
    ]
]

TestCase subclass: StringTests [
    runAll [
        self runTest: #testLiteralQuoting do: [ self testLiteralQuoting ].
        self runTest: #testAtAndAtPut do: [ self testAtAndAtPut ].
        self runTest: #testSizeConcatCopy do: [ self testSizeConcatCopy ].
        self runTest: #testComparisons do: [ self testComparisons ].
        self runTest: #testSymbolRoundTrip do: [ self testSymbolRoundTrip ].
        self runTest: #testHash do: [ self testHash ].
        self runTest: #testPrintAndDisplay do: [ self testPrintAndDisplay ].
        self runTest: #testLiteralAliasing do: [ self testLiteralAliasing ].
        self runTest: #testIncludesAndIndexOf do: [ self testIncludesAndIndexOf ].
    ]

    testLiteralQuoting [
        self assert: 'it''s' size = 4.
    ]
    testAtAndAtPut [
        | s |
        self assert: ('hello' at: 1) = $h.
        self assert: ('hello' at: 1) class == Character.
        s := String new: 3.
        s at: 1 put: $x.
        s at: 2 put: 121.
        self assert: (s at: 1) = $x.
        self assert: (s at: 2) = $y.
    ]
    testSizeConcatCopy [
        self assert: 'hello' size = 5.
        self assert: ('hello' , ' world') = 'hello world'.
        self assert: ('hello' , ' world') size = 11.
        self assert: ('hello' copyFrom: 2 to: 4) = 'ell'.
    ]
    testComparisons [
        self assert: 'abc' = 'abc'.
        self deny: 'abc' = 'abd'.
        self assert: 'abc' < 'abd'.
        self assert: 'abd' > 'abc'.
        self assert: 'ab' < 'abc'.
    ]
    testSymbolRoundTrip [
        self assert: 'hello' asSymbol == #hello.
        self assert: #foo asString asSymbol == #foo.
    ]
    testHash [
        self assert: 'hello' hash = 'hello' hash.
    ]
    "'it''s' is source for the 4-char content it's; printString wraps +
     doubles the embedded quote, giving the 7-char 'it''s' (quote,i,t,
     quote,quote,s,quote) — built via concatenation with $' rather than a
     doubly-escaped string literal, which gets confusing fast."
    testPrintAndDisplay [
        | expected |
        expected := (String with: $') , 'it' , (String with: $')
            , (String with: $') , 's' , (String with: $').
        self assert: 'it''s' printString = expected.
        self assert: 'hello' displayString = 'hello'.
    ]
    "Literal strings are mutable and NOT re-created per call — a mutation
     through one call is visible on the next (v1 documented limitation,
     not a bug: sprint_s06_detail.md #12)."
    testLiteralAliasing [
        | first |
        first := StringTestsAliasHelper lit.
        self assert: first == StringTestsAliasHelper lit.
        first at: 1 put: $X.
        self assert: StringTestsAliasHelper lit = 'Xbc'.
    ]
    testIncludesAndIndexOf [
        self assert: ('hello' includesChar: $e).
        self deny: ('hello' includesChar: $z).
        self assert: ('hello' indexOf: $l ifAbsent: [ -1 ]) = 3.
        self assert: ('hello' indexOf: $z ifAbsent: [ -1 ]) = -1.
    ]
]
