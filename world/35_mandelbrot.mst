"35_mandelbrot.mst — the Strongtalk 'fast floats' Mandelbrot demo
 (gui/reference/pages/tour/fastfloats.html: `Mandelbrot new launch`), rebuilt
 on the MACVM Canvas view as a PIXMAP (docs/CANVAS.md pixel-buffer path).

 The set is computed HERE, in real Smalltalk Double arithmetic — the
 JIT-compiled `<primitive: 100..>` float ops that ARE the 'fast floats' the
 tour page is about (world/08_double.mst). Each escape count maps to an RGB
 triple written straight into a Pixmap (world/36_pixmap.mst) — no colour
 strings, no fillRect command batch. The buffer crosses to the GUI once and is
 blitted in a single putImageData. Rust only transports the bytes; no VM-side
 Canvas primitive is needed (docs/CANVAS.md §7 stays deferred)."
Object subclass: Mandelbrot [
    | maxIter |
    Mandelbrot class >> new [ ^self basicNew init ]
    init [ maxIter := 120. ^self ]
    maxIter: n [ maxIter := n. ^self ]

    "Escape count for c = cr + ci*i: iterations until |z| > 2, capped at
     maxIter (== inside the set). Pure Double arithmetic — this is the hot
     method the JIT compiles, keeping zr2/zi2 to spend one multiply each per
     step instead of three."
    escapeAtRe: cr im: ci [
        | zr zi zr2 zi2 n |
        zr := 0.0. zi := 0.0. zr2 := 0.0. zi2 := 0.0. n := 0.
        [ (zr2 + zi2 < 4.0) and: [ n < maxIter ] ] whileTrue: [
            zi := (2.0 * zr * zi) + ci.
            zr := (zr2 - zi2) + cr.
            zr2 := zr * zr.
            zi2 := zi * zi.
            n := n + 1 ].
        ^n
    ]

    "Render the full set into a fresh `w` x `h` Pixmap and answer it. Square
     pixels: the imaginary axis is centred on 0 and scaled by the SAME step as
     the real axis, so the set is never stretched by the canvas aspect ratio.
     Inside the set is black; escaped points get colourful bands (decimal
     channels, computed with plain integer math — no strings)."
    pixmapForWidth: w height: h [
        | pm rmin step imin ci cr n r g b |
        pm := Pixmap width: w height: h.
        rmin := 0.0 - 2.5.
        step := 3.5 / w asDouble.
        imin := 0.0 - ((h asDouble * step) / 2.0).
        "Strength-reduced coordinates: ci/cr ACCUMULATE by `+ step` (pure
         double-double, fused to native fadd) instead of recomputing
         `int * step` per pixel — a mixed smi x double send whose primitive
         fails every call (the receiver is the int) and takes the boxed
         asDouble fallback, and whose fused caller sites were the source of
         the recurring uncommon traps in the render stats."
        ci := imin.
        0 to: h - 1 do: [ :py |
            cr := rmin.
            0 to: w - 1 do: [ :px |
                n := self escapeAtRe: cr im: ci.
                n >= maxIter
                    ifTrue: [ r := 0. g := 0. b := 0 ]
                    ifFalse: [
                        r := (n * 8) \\ 256.
                        g := (n * 5) \\ 256.
                        b := 64 + ((n * 11) \\ 192) ].
                pm atX: px y: py r: r g: g b: b.
                cr := cr + step ].
            ci := ci + step ].
        ^pm
    ]

    "The raw RGBA buffer the GUI blits (docs/CANVAS.md pixel path) — a
     `w`*`h`*4 ByteArray."
    pixelsForWidth: w height: h [
        ^(self pixmapForWidth: w height: h) bytes
    ]
]
